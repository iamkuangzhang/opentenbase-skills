{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenTenBase System Entry Environment Summary",
  "type": "object",
  "required": [
    "timestamp",
    "host",
    "opentenbase",
    "management",
    "processes",
    "ports",
    "database",
    "topology",
    "consistency",
    "safety",
    "command_evidence",
    "errors"
  ],
  "properties": {
    "timestamp": { "type": "string" },
    "host": {
      "type": "object",
      "properties": {
        "user": { "type": "string" },
        "hostname": { "type": "string" },
        "addresses": { "type": "array", "items": { "type": "string" } }
      }
    },
    "opentenbase": {
      "type": "object",
      "properties": {
        "detected": { "type": "boolean" },
        "confidence": { "type": "string" },
        "detection_evidence": { "type": "array", "items": { "type": "string" } },
        "binary_root": { "type": "string" },
        "psql": { "type": "string" },
        "postgres": { "type": "string" },
        "pg_config": { "type": "string" },
        "server_version": { "type": "string" },
        "psql_version": { "type": "string" },
        "postgres_binary_version": { "type": "string" },
        "pg_config_version": { "type": "string" }
      }
    },
    "management": {
      "type": "object",
      "properties": {
        "selected": { "type": "string" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
        "scores": { "type": "object" },
        "candidates": { "type": "array" },
        "evidence": { "type": "array" }
      }
    },
    "config_files": { "type": "array" },
    "config_topology": { "type": "object" },
    "processes": { "type": "array" },
    "ports": { "type": "array" },
    "database": {
      "type": "object",
      "properties": {
        "reachable_cn": { "type": "array" },
        "server_version": { "type": "string" },
        "current_database": { "type": "string" },
        "current_user": { "type": "string" },
        "pgxc_node_query_ok": { "type": "boolean" },
        "pgxc_node_error": { "type": "string" }
      }
    },
    "topology": {
      "type": "object",
      "properties": {
        "gtm": { "type": "array" },
        "coordinators": { "type": "array" },
        "datanodes": { "type": "array" }
      }
    },
    "consistency": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "warnings": { "type": "array" }
      }
    },
    "safety": {
      "type": "object",
      "properties": {
        "write_operations_allowed": { "type": "boolean" }
      }
    },
    "command_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "purpose": { "type": "string" },
          "argv": { "type": "array", "items": { "type": "string" } },
          "returncode": { "type": "integer" },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" },
          "timeout": { "type": "boolean" },
          "started_at": { "type": "string" },
          "finished_at": { "type": "string" },
          "duration_ms": { "type": "integer" }
        }
      }
    },
    "errors": { "type": "array" }
  }
}
